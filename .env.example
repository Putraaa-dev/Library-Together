# MongoDB Configuration
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/librarytogether?retryWrites=true&w=majority
MONGODB_DB=librarytogether

# Frontend API URL (leave empty if frontend and backend are on same host)
VITE_API_URL=

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB TLS (set to true if certificate validation issues)
MONGODB_TLS_ALLOW_INVALID_CERTS=false

# CORS Configuration (optional)
# CORS_ORIGIN=https://yourdomain.com

# Server Selection Timeout (ms)
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000